# Application
APP_NAME=GauriMobiles
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata

# Database
DB_DRIVER=mysql
DB_HOST=localhost
DB_DATABASE=gauri_mobiles
DB_USERNAME=root
DB_PASSWORD=

# Mail (Gmail SMTP)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

# Email recipients
BACKUP_TO_EMAIL=
INVOICE_TO_EMAIL=

# Database backup
# On Linux/macOS: 'mysqldump' (if in PATH)
# On Windows XAMPP: C:\xampp\mysql\bin\mysqldump.exe
MYSQLDUMP_PATH=mysqldump
